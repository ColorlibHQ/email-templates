<mjml>
  <mj-head>
    <mj-title>Business — Email Template Builder</mj-title>
    <mj-preview>We're Email Template Builder. Services, projects, blog and pricing in one email.</mj-preview>

    <mj-font name="Nunito Sans" href="https://fonts.googleapis.com/css?family=Nunito+Sans:200,300,400,600,700" />

    <mj-include path="./partials/base.mjml" />

    <mj-attributes>
      <mj-all font-family="Nunito Sans, Arial, sans-serif" />
      <mj-text color="#666666" font-size="15px" />
      <mj-button background-color="#f1c638" color="#000000" border-radius="5px" font-weight="600" />
      <mj-class name="h2" color="#000000" font-size="28px" line-height="1.3" font-weight="400" padding="0 0 14px 0" />
      <mj-class name="h2-white" color="#ffffff" font-size="28px" line-height="1.3" font-weight="400" padding="0 0 14px 0" />
      <mj-class name="h3" color="#000000" font-size="18px" line-height="1.3" font-weight="600" padding="0 0 6px 0" />
      <mj-class name="meta" font-size="13px" text-transform="uppercase" letter-spacing="1px" color="#999999" padding="0 0 6px 0" />
    </mj-attributes>

    <mj-style>
      a { color: #f1c638; }
      .nav a { color:#999999; font-size:13px; font-weight:500; text-decoration:none; padding:0 6px; }
      .counter-num { display:block; color:#000000; font-size:34px; font-weight:400; line-height:1.2; }
      .counter-name { display:block; color:#000000; font-size:14px; }
      .project-caption h3 { margin:0; font-size:16px; font-weight:600; color:#ffffff; }
      .project-caption span { font-size:13px; color:#d9d9d9; }
      .pricing-card { border:1px solid #f1c638; padding:24px 16px; text-align:center; border-radius:4px; }
      .pricing-card h3 { margin:0 0 6px 0; font-size:18px; font-weight:400; color:#000; }
      .pricing-card .start { font-weight:600; font-size:13px; color:#000; display:block; margin-bottom:6px; }
      .pricing-card .price { font-size:50px; font-weight:400; color:#000; line-height:1.2; margin:0; }
      .pricing-card .price small { font-size:18px; }
      .pricing-card ul { padding:0; margin:18px 0 18px 0; list-style:none; }
      .pricing-card ul li { margin:0 0 8px 0; color:#666; font-size:14px; }
      .pricing-card a.buy { display:inline-block; padding:8px 22px; background:#f1c638; color:#000; border-radius:5px; text-decoration:none; font-weight:600; font-size:14px; }
    </mj-style>
  </mj-head>

  <mj-body background-color="#f1f1f1" width="600px">

    <!-- Header: logo + nav -->
    <mj-section background-color="#ffffff" padding="20px 30px">
      <mj-column width="35%" vertical-align="middle">
        <mj-text font-weight="700" font-size="20px" padding="0">
          <a href="#" style="color:#000;text-decoration:none;">Business</a>
        </mj-text>
      </mj-column>
      <mj-column width="65%" vertical-align="middle">
        <mj-text align="right" padding="0" font-size="13px" css-class="nav">
          <a href="#">Home</a><a href="#">About</a><a href="#">Works</a><a href="#">Blog</a><a href="#">Contact</a>
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Hero: image left + yellow text panel right -->
    <mj-section background-color="#ffffff" padding="0">
      <mj-column vertical-align="middle" width="50%">
        <mj-image src="images/bg_1.jpg" alt="Email Template Builder" padding="0" />
      </mj-column>
      <mj-column vertical-align="middle" width="50%" background-color="#f1c638">
        <mj-text mj-class="h2" padding="20px 30px 8px 30px" font-size="24px">We're Email Template Builder</mj-text>
        <mj-text padding="0 30px 14px 30px" color="#333333">A small river named Duden flows by their place and supplies it with the necessary regelialia.</mj-text>
        <mj-button href="#" align="left" padding="0 30px 24px 30px" background-color="#000000" color="#ffffff">Shop now</mj-button>
      </mj-column>
    </mj-section>

    <!-- Services -->
    <mj-section background-color="#ffffff" padding="40px 30px 10px 30px">
      <mj-column>
        <mj-text align="center" mj-class="h2">Our Services</mj-text>
        <mj-text align="center">A small river named Duden flows by their place and supplies it with the necessary regelialia.</mj-text>
      </mj-column>
    </mj-section>
    <mj-section background-color="#ffffff" padding="0 20px 40px 20px">
      <mj-column>
        <mj-image src="images/001-diet.png" alt="Web Design" width="50px" padding="10px" />
        <mj-text align="center" mj-class="h3" font-size="18px" font-weight="400">Web Design</mj-text>
        <mj-text align="center">Far far away, behind the word mountains, far from the countries.</mj-text>
      </mj-column>
      <mj-column>
        <mj-image src="images/003-recipe-book.png" alt="Web Development" width="50px" padding="10px" />
        <mj-text align="center" mj-class="h3" font-size="18px" font-weight="400">Web Development</mj-text>
        <mj-text align="center">Far far away, behind the word mountains, far from the countries.</mj-text>
      </mj-column>
    </mj-section>

