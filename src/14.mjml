    <!-- Footer -->
    <mj-wrapper background-color="#000000" padding="40px 30px 30px 30px">
      <mj-section>
        <mj-column>
          <mj-text align="center" color="#ffffff" font-size="22px" padding="0 0 14px 0">203 Fake St. Mountain View, San Francisco, California, USA</mj-text>
          <mj-text align="center" color="#999999" font-size="14px" padding="0 0 18px 0">No longer want to receive these emails? You can <a href="#" style="color:#ffffff;text-decoration:underline;">Unsubscribe here</a></mj-text>
        </mj-column>
