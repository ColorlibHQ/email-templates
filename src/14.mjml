      <mj-column vertical-align="middle" width="50%">
        <mj-image src="images/about.jpg" alt="Business Strategy" padding="0" />
      </mj-column>
      <mj-column vertical-align="middle" width="50%">
        <mj-text mj-class="h2" padding="30px 30px 8px 30px">Business Strategy</mj-text>
        <mj-text padding="0 30px 14px 30px" color="#333333">A small river named Duden flows by their place and supplies it with the necessary regelialia.</mj-text>
        <mj-button href="#" align="left" padding="0 30px 30px 30px" background-color="#000000" color="#ffffff">Read more</mj-button>
      </mj-column>
