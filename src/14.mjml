      <mj-column>
        <mj-image src="images/work-1.jpg" alt="Office Room" href="#" padding="0 5px 8px 0" />
        <mj-text align="center" mj-class="h3" padding="0 5px 0 0"><a href="#" style="color:#000;text-decoration:none;">Office Room</a></mj-text>
        <mj-text align="center" font-size="13px" color="#999999" padding="0 5px 16px 0">Printing</mj-text>
